// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============================================
// USER MODEL - Admin & Students
// ============================================
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(CUSTOMER)
  phone     String?  @db.VarChar(20)
  avatar    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  OWNER
  CUSTOMER
}

// ============================================
// ROOM MODEL - Hostel Rooms
// ============================================
model Room {
  id               Int           @id @default(autoincrement())
  roomNumber       String        @unique @map("room_number") @db.VarChar(20)
  floor            Int
  capacity         Int           @default(1)
  currentOccupancy Int           @default(0) @map("current_occupancy")
  type             RoomType      @default(SINGLE)
  status           RoomStatus    @default(AVAILABLE)
  pricePerMonth    Float         @map("price_per_month")
  amenities        String?       @db.Text
  description      String?       @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("rooms")
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

// ============================================
// BOOKING MODEL - Room Bookings
// ============================================
model Booking {
  id            Int            @id @default(autoincrement())
  studentId     Int            @map("student_id")
  roomId        Int            @map("room_id")
  checkIn       DateTime       @map("check_in")
  checkOut      DateTime?      @map("check_out")
  status        BookingStatus  @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING) @map("payment_status")
  totalAmount   Float          @map("total_amount")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  room    Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

// ============================================
// SOCIAL MEDIA LINKS
// ============================================
model SocialMediaLink {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  link      String   @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("social_media_links")
}

// ============================================
// CMS PAGES - Terms, Privacy, Refund, Cancellation etc.
// ============================================
model CmsPage {
  id        Int      @id @default(autoincrement())
  slug      String   @unique @db.VarChar(100)
  title     String   @db.VarChar(255)
  content   String?  @db.LongText
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_pages")
}

// ============================================
// NOTIFICATION SETTINGS - Channel config per topic
// ============================================
model NotificationSetting {
  id                      Int                           @id @default(autoincrement())
  title                   String                        @db.VarChar(255)
  subTitle                String?                       @map("sub_title") @db.VarChar(255)
  key                     String                        @db.VarChar(100)
  type                    NotificationChannelType       @default(ADMIN)
  mailStatus              NotificationChannelStatus     @default(DISABLE) @map("mail_status")
  smsStatus               NotificationChannelStatus     @default(DISABLE) @map("sms_status")
  pushNotificationStatus  NotificationChannelStatus     @default(DISABLE) @map("push_notification_status")
  createdAt               DateTime                      @default(now()) @map("created_at")
  updatedAt               DateTime                      @updatedAt @map("updated_at")

  @@unique([key, type])
  @@map("notification_settings")
}

enum NotificationChannelType {
  ADMIN
  OWNER
  CUSTOMER
}

enum NotificationChannelStatus {
  ACTIVE
  INACTIVE
  DISABLE
}

// ============================================
// NOTIFICATION MESSAGES - Push notification templates
// ============================================
model NotificationMessage {
  id        Int                        @id @default(autoincrement())
  key       String                     @db.VarChar(100)
  message   String?                    @db.Text
  status    Boolean                    @default(true)
  userType  NotificationMessageUserType @default(CUSTOMER) @map("user_type")
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  @@unique([key, userType])
  @@map("notification_messages")
}

enum NotificationMessageUserType {
  CUSTOMER
  OWNER
}

// ============================================
// ZONE MODEL - Geographic business zones
// ============================================
model Zone {
  id                            Int      @id @default(autoincrement())
  name                          String   @unique @db.VarChar(191)
  displayName                   String?  @map("display_name") @db.VarChar(255)
  coordinates                   String?  @db.Text
  status                        Boolean  @default(true)
  isDefault                     Boolean  @default(false) @map("is_default")
  minimumServiceCharge          Float?   @map("minimum_service_charge")
  perKmServiceCharge            Float?   @map("per_km_service_charge")
  maximumServiceCharge          Float?   @map("maximum_service_charge")
  increasedServiceFee           Float    @default(0) @map("increased_service_fee")
  increasedServiceFeeStatus     Boolean  @default(false) @map("increased_service_fee_status")
  increaseServiceChargeMessage  String?  @map("increase_service_charge_message") @db.VarChar(255)
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  @@map("zones")
}
